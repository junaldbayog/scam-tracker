# Copy to .env and fill in. Never commit .env.

# Postgres connection (local dev: Docker container scamtracker-pg on port 5433)
DATABASE_URL="postgresql://postgres:scamtracker@localhost:5433/scamtracker?schema=public"

# Admin dashboard — set a long random password and secret in production
ADMIN_PASSWORD=""
ADMIN_SESSION_SECRET=""

# Cloudflare Turnstile (captcha on comment forms). Leave empty to disable (dev only).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Random salt for one-way IP hashing (privacy). Set once, never rotate casually.
IP_HASH_SALT=""

# Canonical site URL, no trailing slash (used in metadata, sitemaps, OG images)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
